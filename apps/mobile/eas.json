{
    "cli": {
      "version": ">= 12.0.0",
      "appVersionSource": "remote"
    },
    "build": {
      "development": {
        "developmentClient": true,
        "distribution": "internal",
        "ios": {
          "simulator": false
        }
      },
      "preview": {
        "distribution": "internal",
        "ios": {
          "simulator": false
        }
      },
      "appetize": {
        "distribution": "internal",
        "node": "20.18.3",
        "env": {
          "EXPO_USE_PNPM": "1"
        },
        "android": {
          "buildType": "apk"
        },
        "ios": {
          "simulator": true
        }
      }
    }
  }