{
  "expo": {
    "name": "my_brain",
    "slug": "my-brain",
    "version": "0.0.0",
    "orientation": "portrait",
    "scheme": "mybrain",
    "platforms": [
      "ios",
      "android"
    ],
    "userInterfaceStyle": "dark",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#05070f"
    },
    "android": {
      "package": "app.mybrain.personal",
      "allowBackup": true,
      "fullBackupContent": "@xml/backup_rules"
    },
    "ios": {
      "bundleIdentifier": "app.mybrain.personal",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-sqlite",
        {
          "enableFTS": false
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "3b839cf3-3224-46b3-a62f-0805f301bd20"
      }
    },
    "owner": "gogogogogo"
  }
}
