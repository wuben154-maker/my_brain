{
  "name": "my-brain",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "check": "pnpm typecheck && pnpm lint && pnpm test",
    "brain:mcp": "node --experimental-strip-types --import ./scripts/register-ts-alias.mjs scripts/brain-mcp-server.mjs",
    "export:graph": "node scripts/export-graph.mjs",
    "visual:capture": "node scripts/visual-feedback/capture.mjs",
    "visual:compare": "node scripts/visual-feedback/compare.mjs",
    "visual:report": "node scripts/visual-feedback/report-html.mjs",
    "visual:loop": "node scripts/visual-feedback/loop.mjs",
    "visual:browser": "playwright install chromium",
    "mobile:gate": "node tools/mobile-execution/verify-stage.mjs",
    "scan:secrets": "node tools/scan-secrets.mjs",
    "scan:bundle-secrets": "node tools/scan-bundle-secrets.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-sql": "^2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-force-graph-2d": "^1.27.1",
    "react-force-graph-3d": "^1.29.1",
    "three": "^0.184.0",
    "zustand": "^5.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "better-sqlite3": "^11.9.1",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "happy-dom": "^20.9.0",
    "husky": "^9.1.7",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.52.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^7.0.4",
    "vitest": "^3.0.9"
  }
}
