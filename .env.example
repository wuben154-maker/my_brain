# =============================================================================
# my_brain — environment template
# Copy to `.env.local` (repo root) for local dev, or configure keys in the mobile
# app: Settings → Provider settings. Never commit real values.
# =============================================================================

# --- Mobile companion (Metro / dev-client only — NOT embedded in release APK/IPA) ---
# Volcengine / 豆包端到端实时语音 — https://www.volcengine.com/docs/6561/1594356
DOUBAO_VOICE_APP_ID=
DOUBAO_VOICE_ACCESS_TOKEN=
DOUBAO_VOICE_SECRET_KEY=

# ModelScope OpenAI-compatible text LLM
MODELSCOPE_LLM_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_LLM_API_KEY=
MODELSCOPE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# --- Legacy Web / Tauri (Vite dev surface — optional) ---
VITE_VOICE_PROVIDER=mock
VITE_LLM_PROVIDER=mock

# OpenAI — optional Realtime voice + OpenAI LLM
VITE_OPENAI_API_KEY=
VITE_OPENAI_LLM_MODEL=gpt-4o-mini
VITE_OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Volcengine / 豆包 (VITE_VOICE_PROVIDER=volc-realtime)
VITE_VOLC_APP_ID=
VITE_VOLC_ACCESS_KEY=
VITE_VOLC_CONNECT_ID=
VITE_VOLC_REALTIME_MODEL=2.2.0.0

# ModelScope (VITE_LLM_PROVIDER=modelscope)
VITE_MODELSCOPE_API_KEY=
VITE_MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
VITE_MODELSCOPE_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# Domestic LLM adapter skeleton (VITE_LLM_PROVIDER=domestic-mock)
VITE_DOMESTIC_LLM_API_KEY=
VITE_DOMESTIC_LLM_BASE_URL=

# Live public news fetch (RSS + GitHub + arXiv). Default off — demo placeholders.
VITE_NEWS_LIVE_FETCH=0

# Memory engine — mock by default
VITE_MEMORY_PROVIDER=mock
VITE_EVERMEMOS_BASE_URL=http://localhost:1995
VITE_EVERMEMOS_API_KEY=
VITE_EVERMEMOS_USER_ID=my_brain_local

# CI / manual smoke (not read by app shell)
# KP01_LIVE_SOURCE_SMOKE=1
