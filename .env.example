# OpenAI — required for voice (Realtime) and LLM tasks
VITE_OPENAI_API_KEY=

# Optional model overrides
VITE_OPENAI_LLM_MODEL=gpt-4o-mini
VITE_OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview

# Memory engine (M0) — mock by default; set evermemos when EverMemOS sidecar is running
VITE_MEMORY_PROVIDER=mock
VITE_EVERMEMOS_BASE_URL=http://localhost:1995
VITE_EVERMEMOS_API_KEY=
VITE_EVERMEMOS_USER_ID=my_brain_local
